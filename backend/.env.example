# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/transitops"

# JWT signing secret ΓÇô use a long random string in production
JWT_SECRET="replace_with_a_long_random_secret"

# Access token expiry (jsonwebtoken format)
JWT_EXPIRES_IN="8h"

# Server port
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# SMTP / Nodemailer (for forgot-password OTP emails)
# Use Gmail App Password, Mailtrap, Resend, etc.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="TransitOps <your_email@gmail.com>"

# Geoapify address autocomplete (https://myprojects.geoapify.com/ – free tier available)
# Leave blank or omit to disable location search (returns 503)
GEOAPIFY_API_KEY="replace_with_your_geoapify_key"
