generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
  DRIVER
}

enum VehicleType {
  VAN
  TRUCK
  BUS
  CAR
  BIKE
}

enum FuelType {
  DIESEL
  PETROL
  CNG
  ELECTRIC
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP      // vehicle is undergoing maintenance
  MAINTENANCE  // legacy alias – kept for backward compatibility
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  ON_LEAVE
  SUSPENDED
}

enum TripStatus {
  DRAFT        // created, vehicle/driver not yet assigned or dispatched
  PENDING      // legacy alias – kept for backward compatibility
  DISPATCHED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  OIL_CHANGE
  TYRE_ROTATION
  FULL_SERVICE
  BRAKE_SERVICE
  ENGINE_CHECK
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum ExpenseCategory {
  FUEL
  TOLL
  PARKING
  DRIVER_ALLOWANCE
  LOADING
  OTHER
}

enum DocumentCategory {
  DRIVER_LICENSE
  VEHICLE_REGISTRY
  INSURANCE_CERTIFICATE
  PUC_CERTIFICATE
  FITNESS_CERTIFICATE
  MAINTENANCE_INVOICE
  FUEL_RECEIPT
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  driverProfile   Driver?

  tripsCreated    Trip[]           @relation("TripCreatedBy")
  fuelLogs        FuelLog[]        @relation("FuelLogCreatedBy")
  expenses        Expense[]        @relation("ExpenseCreatedBy")
  maintenanceLogs MaintenanceLog[] @relation("MaintenanceCreatedBy")
  auditLogs       AuditLog[]
  documents       Document[]       @relation("DocumentUploadedBy")

  @@map("users")
}

model Vehicle {
  id                  String        @id @default(cuid())
  registrationNumber  String        @unique @map("registration_number")
  make                String
  model               String
  year                Int
  type                VehicleType
  fuelType            FuelType      @map("fuel_type")
  tankCapacity        Float         @map("tank_capacity")
  currentOdometer     Float         @default(0) @map("current_odometer")
  status              VehicleStatus @default(AVAILABLE)
  maximumLoadCapacity Float?        @map("maximum_load_capacity")  // kg
  acquisitionCost     Float?        @map("acquisition_cost")       // currency units
  region              String?
  insuranceExpiry     DateTime?     @map("insurance_expiry")
  pucExpiry           DateTime?     @map("puc_expiry")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  trips                Trip[]
  fuelLogs             FuelLog[]
  expenses             Expense[]
  maintenanceLogs      MaintenanceLog[]
  maintenanceSchedules MaintenanceSchedule[]
  documents            Document[]

  @@map("vehicles")
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  phone           String       @unique
  email           String?
  licenseNumber   String       @unique @map("license_number")
  licenseCategory String       @map("license_category")
  licenseExpiry   DateTime     @map("license_expiry")
  safetyScore     Float        @default(100) @map("safety_score")
  status          DriverStatus @default(AVAILABLE)

  userId          String?      @unique @map("user_id")
  user            User?        @relation(fields: [userId], references: [id])

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  trips     Trip[]
  documents Document[]

  @@map("drivers")
}

model Trip {
  id                 String     @id @default(cuid())
  tripNumber         String     @unique @map("trip_number")
  originAddress      String     @map("origin_address")
  originLat          Float      @map("origin_lat")
  originLng          Float      @map("origin_lng")
  destinationAddress String     @map("destination_address")
  destinationLat     Float      @map("destination_lat")
  destinationLng     Float      @map("destination_lng")
  distanceKm         Float?     @map("distance_km")
  cargoWeight        Float?     @map("cargo_weight")              // kg – validated against vehicle.maximumLoadCapacity
  revenue            Float?                                       // for ROI: (revenue - costs) / acquisitionCost
  plannedDeparture   DateTime   @map("planned_departure")
  plannedArrival     DateTime?  @map("planned_arrival")
  actualDeparture    DateTime?  @map("actual_departure")
  actualArrival      DateTime?  @map("actual_arrival")
  startOdometer      Float?     @map("start_odometer")
  endOdometer        Float?     @map("end_odometer")
  status             TripStatus @default(DRAFT)
  notes              String?

  // Nullable until dispatch – a DRAFT trip may not have vehicle/driver assigned yet
  vehicleId          String?    @map("vehicle_id")
  driverId           String?    @map("driver_id")
  createdById        String     @map("created_by_id")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id])
  driver    Driver?   @relation(fields: [driverId], references: [id])
  createdBy User      @relation("TripCreatedBy", fields: [createdById], references: [id])
  fuelLogs  FuelLog[]
  expenses  Expense[]

  @@map("trips")
}

model FuelLog {
  id             String   @id @default(cuid())
  vehicleId      String   @map("vehicle_id")
  tripId         String?  @map("trip_id")
  date           DateTime
  litres         Float
  pricePerLitre  Float    @map("price_per_litre")
  totalCost      Float    @map("total_cost")
  odometerAtFill Float    @map("odometer_at_fill")
  location       String?
  receiptUrl     String?  @map("receipt_url")
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  trip      Trip?   @relation(fields: [tripId], references: [id])
  createdBy User    @relation("FuelLogCreatedBy", fields: [createdById], references: [id])

  @@map("fuel_logs")
}

model Expense {
  id          String          @id @default(cuid())
  vehicleId   String          @map("vehicle_id")
  tripId      String?         @map("trip_id")
  category    ExpenseCategory
  amount      Float
  date        DateTime
  description String?
  receiptUrl  String?         @map("receipt_url")
  createdById String          @map("created_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  trip      Trip?   @relation(fields: [tripId], references: [id])
  createdBy User    @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@map("expenses")
}

model MaintenanceLog {
  id                String            @id @default(cuid())
  vehicleId         String            @map("vehicle_id")
  type              MaintenanceType
  description       String?
  date              DateTime
  cost              Float?
  odometerAtService Float?            @map("odometer_at_service")
  vendorName        String?           @map("vendor_name")
  vendorContact     String?           @map("vendor_contact")
  status            MaintenanceStatus @default(SCHEDULED)
  createdById       String            @map("created_by_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id])
  createdBy User       @relation("MaintenanceCreatedBy", fields: [createdById], references: [id])
  documents Document[]

  @@map("maintenance_logs")
}

model MaintenanceSchedule {
  id              String          @id @default(cuid())
  vehicleId       String          @map("vehicle_id")
  serviceType     MaintenanceType @map("service_type")
  intervalKm      Float           @map("interval_km")
  lastOdometer    Float           @map("last_odometer")
  nextDueOdometer Float           @map("next_due_odometer")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenance_schedules")
}

model Settings {
  id           String   @id @default(cuid())
  depotName    String   @default("TransitOps HQ") @map("depot_name")
  currency     String   @default("INR")
  distanceUnit String   @default("km") @map("distance_unit")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  revokedAt DateTime @default(now()) @map("revoked_at")
  expiresAt DateTime @map("expires_at")

  @@map("revoked_tokens")
}

model PasswordResetOtp {
  id        String   @id @default(cuid())
  email     String
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_otps")
}

model Document {
  id           String           @id @default(cuid())
  originalName String           @map("original_name")
  storedName   String           @map("stored_name")
  mimeType     String           @map("mime_type")
  sizeBytes    Int              @map("size_bytes")
  category     DocumentCategory
  expiryDate   DateTime?        @map("expiry_date")

  vehicleId        String?         @map("vehicle_id")
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  driverId         String?         @map("driver_id")
  driver           Driver?         @relation(fields: [driverId], references: [id], onDelete: Cascade)

  maintenanceLogId String?         @map("maintenance_log_id")
  maintenanceLog   MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)

  uploadedById     String          @map("uploaded_by_id")
  uploadedBy       User            @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@map("documents")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
